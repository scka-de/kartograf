GOOGLE_API_KEY=
GITHUB_TOKEN=

# ADK eval runtime. For Gemini Developer API, set GOOGLE_API_KEY above and
# keep GOOGLE_GENAI_USE_VERTEXAI=0. For Vertex AI, set this to 1 and provide
# project/location values for a project with Agent Platform API enabled.
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Optional local cache roots used by scripts/run_demo.sh in restricted shells.
MPLCONFIGDIR=data/matplotlib
XDG_CACHE_HOME=data/cache
