GOOGLE_API_KEY=

# Vertex AI alternative. Leave GOOGLE_GENAI_USE_VERTEXAI=0 to use the
# Gemini Developer API with the key above. Set to 1 and fill the project
# fields to use Vertex (the project must have the Agent Platform API enabled,
# and GOOGLE_CLOUD_PROJECT must be the project ID, not the display name).
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Optional. Override where embedding caches are written. Default is
# ~/.cache/kartograf/embeddings.
# KARTOGRAF_CACHE_DIR=
